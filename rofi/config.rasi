configuration {
	modi: "window,drun,run,ssh";
	show-icons: true;
	terminal: "kitty";
	drun-display-format: "{icon} {name}";
	location: 0;
	disable-history: false;
	hide-scollbar: true;
	display-drun: "   Apps ";
	display-run: "   Run ";
	display-window: " 﩯  Window";
	sidebar-mode: true;
}

//@theme "solarized" 

@theme "/usr/share/rofi/themes/Arc-Dark.rasi"
